<?xml version="1.0" encoding="utf-8"?>
<!--
  Demo I - SQL Database Project (Database-as-Code)
  SDK-style project (Microsoft.Build.Sql / DacFx). 선언형 "최종 상태"를
  담는다. 빌드하면 GameDb.dacpac 이 산출되고, 배포 시 SqlPackage 가
  대상 DB와의 차이를 계산해 마이그레이션한다(= 데모 K 파이프라인의 빌드 산출물).

  빌드(예): dotnet build   또는   sqlpackage 로 별도 빌드 도구 사용
  배포(보류): 실제 배포는 데모 K 워크플로에서 가드 처리. 여기서는 빌드/모델 검증만.

  DSP: Sql160 (SQL Server 2022 엔진 = Azure SQL MI 호환 표면).
-->
<Project Sdk="Microsoft.Build.Sql/2.2.0">
  <PropertyGroup>
    <Name>GameDb</Name>
    <ProjectGuid>{4E9F1B27-1C0A-4E3D-9A2B-7C6D5E4F0A11}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.Sql160DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
    <TargetDatabaseSet>True</TargetDatabaseSet>
  </PropertyGroup>
</Project>
