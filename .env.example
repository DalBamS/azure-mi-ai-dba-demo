# ---------------------------------------------------------------------------
# azure-mi-ai-dba-demo — environment variable template
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in values LOCALLY. Never commit `.env`.
# Secrets should ideally come from Azure Key Vault; these vars are the
# fallback/local-dev path. NO real connection strings or secrets in git.
# ---------------------------------------------------------------------------
# NOTE: This root file configures only the DEMO SCRIPTS (game-driver, seed,
# workload) that connect to Azure SQL MI. The Demo Cockpit web app and its
# AI 진단 패널 (Azure AI Foundry) use a SEPARATE env file. See
# `cockpit/.env.example` for AI_FOUNDRY_ENDPOINT / _API_KEY / _DEPLOYMENT /
# _REASONING_EFFORT / _MAX_COMPLETION_TOKENS / _TEMPERATURE / _AUTH.
# ---------------------------------------------------------------------------

# --- Azure SQL Managed Instance target ---
# Prefer the SQL MI *public* or *private* FQDN. Example:
#   your-mi.<dns-zone>.database.windows.net
SQLMI_SERVER=
SQLMI_DATABASE=gamedb
SQLMI_PORT=1433

# --- Authentication ---
# AUTH_MODE: "aad-integrated" | "aad-password" | "aad-service-principal" | "sql"
# Prefer Entra ID (AAD) over SQL auth. SQL auth is for local/dev only.
AUTH_MODE=aad-integrated

# Only used when AUTH_MODE=sql (LOCAL/DEV ONLY — do not use in shared demos)
SQL_USER=
SQL_PASSWORD=

# Only used when AUTH_MODE=aad-service-principal
AAD_TENANT_ID=
AAD_CLIENT_ID=
AAD_CLIENT_SECRET=

# --- Key Vault (preferred secret source) ---
# When set, scripts resolve SQL_PASSWORD / AAD_CLIENT_SECRET from Key Vault
# instead of the vars above.
KEYVAULT_NAME=
KEYVAULT_SECRET_SQL_PASSWORD=sqlmi-admin-password

# --- Driver / connection behavior ---
# ODBC driver name used by the Python game-driver (pyodbc).
ODBC_DRIVER=ODBC Driver 18 for SQL Server
# Encrypt/TrustServerCertificate for ODBC Driver 18 (encrypt on by default).
ODBC_ENCRYPT=yes
ODBC_TRUST_SERVER_CERT=no

# Mimic the production C++/MSOLEDBSQL (OLE DB) client SET options so that
# plan-regression / "fast in SSMS, slow in app" demos are authentic.
# When true, the game-driver issues `SET ARITHABORT OFF` on connect.
MIMIC_OLEDB_SET_OPTIONS=true

# --- Seed data scale (parameterized; see schema/seed) ---
SEED_PROFILE=default        # default | smoke
SEED_PLAYERS=100000
SEED_ITEMS_PER_PLAYER=20
SEED_MATCHES=200000

# --- Workload driver mix (game-driver) ---
WORKLOAD_CONCURRENCY=8
WORKLOAD_DURATION_SECONDS=0   # 0 = run until stopped
WORKLOAD_MIX_CURRENCY_TRANSFER=40
WORKLOAD_MIX_INVENTORY_UPDATE=40
WORKLOAD_MIX_RANKING_QUERY=20
