# Demo Cockpit mode. Defaults to mock unless all live guards are set.
COCKPIT_MODE=mock
COCKPIT_ALLOW_LIVE=0
COCKPIT_PORT=5177

# Live SQL Managed Instance execution (optional; never commit real values).
SQLMI_SERVER=
SQLMI_DATABASE=gamedb

# Azure AI Foundry / Azure OpenAI chat-completions endpoint.
# AI_FOUNDRY_ENDPOINT must be the full chat-completions POST URL.
# Example shapes:
# https://<resource>.services.ai.azure.com/openai/v1/chat/completions
# https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-08-01-preview
AI_FOUNDRY_ENDPOINT=
AI_FOUNDRY_API_KEY=
AI_FOUNDRY_DEPLOYMENT=
# Optional; defaults to 2000. Reasoning models may consume budget before visible output.
AI_FOUNDRY_MAX_COMPLETION_TOKENS=
# Optional. Leave unset for reasoning models like gpt-5-mini, which only allow the default temperature.
AI_FOUNDRY_TEMPERATURE=
# Optional reasoning effort: minimal, low, medium, or high.
# For reasoning models like gpt-5-mini, use minimal or low to avoid empty content and reduce latency.
# Medium/high may require a much larger max_completion_tokens budget.
AI_FOUNDRY_REASONING_EFFORT=
# Header style: api-key (default) or bearer.
AI_FOUNDRY_AUTH=api-key
