# Demo Cockpit mode. Defaults to mock unless all live guards are set.
COCKPIT_MODE=mock
COCKPIT_ALLOW_LIVE=0
COCKPIT_PORT=5177

# Live SQL Managed Instance execution (optional; never commit real values).
SQLMI_SERVER=
SQLMI_DATABASE=gamedb

# Azure AI Foundry / Azure OpenAI chat-completions endpoint.
# AI_FOUNDRY_ENDPOINT must be the full POST URL, including the path and api-version.
# Example shapes:
# https://<resource>.services.ai.azure.com/models/chat/completions?api-version=2024-05-01-preview
# https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-08-01-preview
AI_FOUNDRY_ENDPOINT=
AI_FOUNDRY_API_KEY=
AI_FOUNDRY_DEPLOYMENT=
# Header style: api-key (default) or bearer.
AI_FOUNDRY_AUTH=api-key
